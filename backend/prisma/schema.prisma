generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  perfil    String   @default("COLLABORATOR")
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  solicitacoes SolicitacaoReembolso[]
  historicos   HistoricoSolicitacao[]
}

model Categoria {
  id        String   @id @default(uuid())
  nome      String   @unique
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  solicitacoes SolicitacaoReembolso[]
}

model SolicitacaoReembolso {
  id                  String   @id @default(uuid())
  solicitanteId       String
  categoriaId         String
  descricao           String
  valor               Float
  dataDespesa         DateTime
  status              String   @default("PENDING")
  justificativaRejeicao String?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  solicitante User       @relation(fields: [solicitanteId], references: [id])
  categoria   Categoria  @relation(fields: [categoriaId], references: [id])
  anexos      Anexo[]
  historicos  HistoricoSolicitacao[]
}

model Anexo {
  id             String   @id @default(uuid())
  solicitacaoId  String
  nomeArquivo    String
  urlArquivo     String
  tipoArquivo    String
  criadoEm       DateTime @default(now())

  solicitacao SolicitacaoReembolso @relation(fields: [solicitacaoId], references: [id])
}

model HistoricoSolicitacao {
  id             String   @id @default(uuid())
  solicitacaoId  String
  usuarioId      String
  acao           String
  observacao     String?
  criadoEm       DateTime @default(now())

  solicitacao SolicitacaoReembolso @relation(fields: [solicitacaoId], references: [id])
  usuario     User                 @relation(fields: [usuarioId], references: [id])
}
