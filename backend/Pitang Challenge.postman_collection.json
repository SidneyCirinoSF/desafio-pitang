      "name": "auth",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login bem-sucedido\", function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "pm.test(\"Retorna dados do usu\u00e1rio\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.user).to.be.an('object');",
                  "    pm.expect(body.user.email).to.equal('admin@sistema.com');",
                  "    pm.expect(body.user.perfil).to.equal('ADMIN');",
                  "});",
                  "pm.test(\"Cookie token foi definido\", function () {",
                  "    const cookies = pm.response.headers.toObject()['set-cookie'];",
                  "    pm.expect(cookies).to.not.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@sistema.com\",\n    \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
